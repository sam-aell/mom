<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>A Special Surprise For Bhumika 💖</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg1: #fff0f6;
      --bg2: #ffe4ec;
      --card: rgba(255, 255, 255, 0.75);
      --text: #7a1f4d;
      --accent: #ff4f8b;
      --accent-dark: #e63d79;
      --gold: #ffbf47;
      --shadow: 0 10px 30px rgba(255, 79, 139, 0.18);
      --radius: 24px;
    }

    body {
      font-family: "Segoe UI", Arial, sans-serif;
      background: linear-gradient(135deg, var(--bg1), var(--bg2));
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .music-btn {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 1000;
      border: none;
      background: white;
      box-shadow: var(--shadow);
      width: 54px;
      height: 54px;
      border-radius: 50%;
      font-size: 1.4rem;
      cursor: pointer;
    }

    .container {
      width: min(1100px, 92%);
      margin: 0 auto;
      padding: 40px 0 80px;
    }

    .screen {
      display: none;
      min-height: 100vh;
      padding: 40px 0;
      align-items: center;
      justify-content: center;
    }

    .screen.active {
      display: flex;
      animation: fadeIn 0.8s ease;
    }

    .card {
      width: 100%;
      background: var(--card);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.55);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 32px 24px;
      text-align: center;
    }

    h1 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      margin-bottom: 18px;
      line-height: 1.2;
    }

    h2 {
      font-size: clamp(1.5rem, 3vw, 2.3rem);
      margin: 18px 0;
    }

    p {
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .subtext {
      margin-bottom: 20px;
      color: #8f3d67;
    }

    .password-box {
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      margin-top: 18px;
    }

    .password-box input {
      width: min(320px, 90%);
      padding: 14px 16px;
      border-radius: 14px;
      border: 2px solid #ffc4d9;
      outline: none;
      font-size: 1rem;
      text-align: center;
      background: rgba(255,255,255,0.95);
    }

    .btn {
      display: inline-block;
      padding: 14px 26px;
      border-radius: 999px;
      border: none;
      background: var(--accent);
      color: white;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(255, 79, 139, 0.3);
      transition: transform .2s ease, background .2s ease;
      text-decoration: none;
    }

    .btn:hover {
      transform: translateY(-2px);
      background: var(--accent-dark);
    }

    .error {
      min-height: 24px;
      color: #d72660;
      font-weight: 700;
    }

    .balloon-wrap {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(90px, 1fr));
      gap: 18px;
      margin: 28px 0 20px;
      align-items: end;
    }

    .balloon {
      width: 90px;
      height: 120px;
      border-radius: 50% 50% 45% 45%;
      margin: 0 auto;
      position: relative;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 800;
      box-shadow: 0 8px 18px rgba(0,0,0,.12);
      user-select: none;
      transition: transform .2s ease;
    }

    .balloon:hover {
      transform: scale(1.06);
    }

    .balloon::after {
      content: "";
      position: absolute;
      bottom: -24px;
      left: 50%;
      width: 2px;
      height: 24px;
      background: #c98da7;
      transform: translateX(-50%);
    }

    .balloon.red { background: #ff5c8a; }
    .balloon.blue { background: #5ca9ff; }
    .balloon.yellow { background: #ffbf47; }
    .balloon.purple { background: #b56cff; }
    .balloon.green { background: #47c98b; }

    .balloon.popped {
      animation: pop .35s ease forwards;
      pointer-events: none;
    }

    .message-reveal {
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 800;
      margin-top: 16px;
      color: var(--accent-dark);
    }

    .next-btn {
      margin-top: 22px;
    }

    .gift-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 20px;
      margin-top: 26px;
    }

    .gift {
      background: rgba(255,255,255,0.9);
      border-radius: 22px;
      padding: 24px 16px;
      box-shadow: var(--shadow);
      cursor: pointer;
      transition: transform .25s ease;
      border: 2px dashed #ffc0d6;
    }

    .gift:hover {
      transform: translateY(-6px) scale(1.02);
    }

    .gift .icon {
      font-size: 2.4rem;
      margin-bottom: 10px;
    }

    .gift .label {
      font-weight: 700;
      font-size: 1.05rem;
    }

    .gift-content {
      display: none;
      margin-top: 26px;
      animation: fadeIn .4s ease;
    }

    .gift-content.active {
      display: block;
    }

    .memory-highlight {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-top: 22px;
    }

    .memory-card, .gallery-card {
      background: rgba(255,255,255,0.9);
      border-radius: 22px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .memory-card img, .gallery-card img {
      width: 100%;
      height: 280px;
      object-fit: cover;
      display: block;
    }

    .memory-card .caption, .gallery-card .caption {
      padding: 14px 16px 18px;
      font-weight: 700;
      color: var(--text);
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 22px;
      margin-top: 26px;
    }

    .final-heart {
      font-size: 3rem;
      margin: 14px 0;
      animation: pulse 1.4s infinite;
    }

    .footer-love {
      margin-top: 18px;
      color: #944465;
      font-weight: 700;
    }

    .hearts {
      margin-top: 20px;
      font-size: 1.5rem;
      letter-spacing: 6px;
      line-height: 1.8;
    }

    .floating {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
    }

    .heart {
      position: absolute;
      bottom: -40px;
      font-size: 20px;
      opacity: 0.7;
      animation: floatUp linear infinite;
    }

    .card > * {
      position: relative;
      z-index: 2;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pop {
      0% { transform: scale(1); opacity: 1; }
      100% { transform: scale(1.6); opacity: 0; }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.12); }
    }

    @keyframes floatUp {
      from { transform: translateY(0) rotate(0); opacity: .75; }
      to { transform: translateY(-120vh) rotate(180deg); opacity: 0; }
    }

    @media (max-width: 640px) {
      .card {
        padding: 24px 16px;
      }
      .balloon {
        width: 74px;
        height: 102px;
        font-size: 0.9rem;
      }
      .memory-card img, .gallery-card img {
        height: 220px;
      }
    }
  </style>
</head>
<body>
  <button class="music-btn" id="musicToggle" aria-label="Toggle music">🎵</button>

  <audio id="bgMusic" loop>
    <source src="assets/music/birthday.mp3" type="audio/mpeg" />
  </audio>

  <div class="floating" id="floatingHearts"></div>

  <section class="screen active" id="screen1">
    <div class="container">
      <div class="card">
        <h1>💖 A Special Surprise For Someone Very Special 💖</h1>
        <p class="subtext">Enter the secret password to continue</p>

        <div class="password-box">
          <input type="password" id="passwordInput" placeholder="Enter password" />
          <button class="btn" onclick="checkPassword()">Unlock ✨</button>
          <div class="error" id="errorMsg"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="screen" id="screen2">
    <div class="container">
      <div class="card">
        <h2>Pop the Balloons 🎈</h2>

        <div class="balloon-wrap" id="balloonWrap">
          <div class="balloon red" data-letter="You">You</div>
          <div class="balloon blue" data-letter="Are">Are</div>
          <div class="balloon yellow" data-letter="Very">Very</div>
          <div class="balloon purple" data-letter="Special">Special</div>
        </div>

        <h2 id="specialMsg" style="display:none;">You Are Very Special ❤️</h2>
        <button class="btn next-btn" id="toGiftBtn" style="display:none;" onclick="showScreen('screen3')">Next Surprise 🎁</button>
      </div>
    </div>
  </section>

  <section class="screen" id="screen3">
    <div class="container">
      <div class="card">
        <h2>Open Your Gifts 🎁</h2>

        <div class="gift-grid">
          <div class="gift" onclick="openGift('gift1')">
            <div class="icon">🎂</div>
            <div class="label">Happy Birthday! 🎂</div>
          </div>

          <div class="gift" onclick="openGift('gift2')">
            <div class="icon">📷</div>
            <div class="label">❤️ Best Memories ❤️</div>
          </div>

          <div class="gift" onclick="openGift('gift3')">
            <div class="icon">🌸</div>
            <div class="label">✨ Best Memories ✨</div>
          </div>
        </div>

        <div class="gift-content" id="gift1">
          <h2>🎂 Happy Birthday! 🎂</h2>
          <p>
            Wishing you lots of happiness, smiles, unforgettable memories,
            and a day as beautiful as your heart. 💖
          </p>
        </div>

        <div class="gift-content" id="gift2">
          <div class="memory-highlight">
            <div class="memory-card">
              <img src="assets/images/IMG_20260710_231037_590.jpg" alt="Our memory" loading="lazy">
              <div class="caption">❤️ Best Memories ❤️</div>
            </div>
          </div>
        </div>

        <div class="gift-content" id="gift3">
          <div class="memory-highlight">
            <div class="memory-card">
              <img src="assets/images/IMG_20260713_170404.jpg" alt="Best memories" loading="lazy">
              <div class="caption">✨ Best Memories ✨</div>
            </div>
          </div>
        </div>

        <button class="btn next-btn" onclick="showScreen('screen4')">Continue →</button>
      </div>
    </div>
  </section>

  <section class="screen" id="screen4">
    <div class="container">
      <div class="card">
        <h2>Our Beautiful Memories ❤️</h2>

        <div class="gallery">
          <div class="gallery-card">
            <img src="assets/images/IMG_20260420_235953_656.jpg" alt="Memory 1" loading="lazy">
            <div class="caption">💕 Sweet Moments</div>
          </div>

          <div class="gallery-card">
            <img src="assets/images/IMG_20260712_094432.jpg" alt="Memory 2" loading="lazy">
            <div class="caption">🌸 Golden Days</div>
          </div>

          <div class="gallery-card">
            <img src="assets/images/IMG_20260713_170404.jpg" alt="Memory 3" loading="lazy">
            <div class="caption">✨ Forever Friends</div>
          </div>

          <div class="gallery-card">
            <img src="assets/images/file_000000004d787208b910421ed76677d6.png" alt="Memory 4" loading="lazy">
            <div class="caption">💖 Cherished</div>
          </div>

          <div class="gallery-card">
            <img src="assets/images/1142902282229426.jpg" alt="Memory 5" loading="lazy">
            <div class="caption">🎈 Precious</div>
          </div>

          <div class="gallery-card">
            <img src="assets/images/IMG_20260710_231037_590.jpg" alt="Memory 6" loading="lazy">
            <div class="caption">👑 Beautiful</div>
          </div>
        </div>

        <button class="btn next-btn" onclick="showScreen('screen5')">One Last Surprise ✨</button>
      </div>
    </div>
  </section>

  <section class="screen" id="screen5">
    <div class="container">
      <div class="card">
        <h1>Happy Birthday Bhumika ❤️</h1>
        <div class="final-heart">💖</div>
        <p>
          May your life always be filled with love, laughter, peace, and all the
          beautiful moments you deserve.
        </p>
        <p class="footer-love">Made with ❤️ by Your Best Friend</p>
        <div class="hearts">💕💓💗💕💝💗💕💗💝💗💖💗💓💕💗💖💖💓</div>
      </div>
    </div>
  </section>

  <script>
    const correctPassword = "bhumika";
    let poppedCount = 0;

    function checkPassword() {
      const input = document.getElementById("passwordInput").value.trim();
      const error = document.getElementById("errorMsg");

      if (input.toLowerCase() === correctPassword.toLowerCase()) {
        error.textContent = "";
        showScreen("screen2");
      } else {
        error.textContent = "Oops! Wrong Password ❤️ Try Again.";
      }
    }

    function showScreen(id) {
      document.querySelectorAll(".screen").forEach(screen => {
        screen.classList.remove("active");
      });
      document.getElementById(id).classList.add("active");
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    document.querySelectorAll(".balloon").forEach(balloon => {
      balloon.addEventListener("click", function () {
        if (this.classList.contains("popped")) return;
        this.classList.add("popped");
        poppedCount++;

        if (poppedCount === document.querySelectorAll(".balloon").length) {
          setTimeout(() => {
            document.getElementById("specialMsg").style.display = "block";
            document.getElementById("toGiftBtn").style.display = "inline-block";
          }, 400);
        }
      });
    });

    function openGift(id) {
      document.querySelectorAll(".gift-content").forEach(box => {
        box.classList.remove("active");
      });
      document.getElementById(id).classList.add("active");
    }

    const music = document.getElementById("bgMusic");
    const musicToggle = document.getElementById("musicToggle");
    let playing = false;

    musicToggle.addEventListener("click", async () => {
      try {
        if (!playing) {
          await music.play();
          musicToggle.textContent = "🔊";
          playing = true;
        } else {
          music.pause();
          musicToggle.textContent = "🎵";
          playing = false;
        }
      } catch (e) {
        musicToggle.textContent = "🎵";
      }
    });

    function createHearts() {
      const wrap = document.getElementById("floatingHearts");
      const icons = ["💖", "💕", "💗", "💓", "💝"];
      setInterval(() => {
        const heart = document.createElement("div");
        heart.className = "heart";
        heart.textContent = icons[Math.floor(Math.random() * icons.length)];
        heart.style.left = Math.random() * 100 + "vw";
        heart.style.animationDuration = (6 + Math.random() * 5) + "s";
        heart.style.fontSize = (16 + Math.random() * 18) + "px";
        wrap.appendChild(heart);

        setTimeout(() => heart.remove(), 12000);
      }, 600);
    }

    createHearts();
  </script>
</body>
</html>